<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DentistAssistantAI.App.ViewModels"
             xmlns:models="clr-namespace:DentistAssistantAI.App.Models"
             xmlns:templates="clr-namespace:DentistAssistantAI.App.Templates"
             x:Class="DentistAssistantAI.App.MainPage"
             x:DataType="vm:MainPageViewModel"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppBackground}">

    <ContentPage.Resources>
        <ResourceDictionary>

            <!-- ── AI bubble ── -->
            <DataTemplate x:Key="AiMessageTemplate"
                          x:DataType="models:ChatMessageItem">
                <Grid Padding="12,4,64,4">
                    <Grid ColumnDefinitions="38,*" ColumnSpacing="8">

                        <Border Grid.Column="0"
                                Background="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 19"
                                Stroke="Transparent"
                                WidthRequest="38"
                                HeightRequest="38"
                                VerticalOptions="End">
                            <Label Text="🦷"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   FontSize="20" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="3">
                            <Border Background="{StaticResource AiBubble}"
                                    StrokeShape="RoundRectangle 18,18,18,2"
                                    Stroke="Transparent"
                                    Padding="14,10">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.15" />
                                </Border.Shadow>
                                <Label Text="{Binding Text}"
                                       TextColor="{StaticResource TextPrimary}"
                                       LineBreakMode="WordWrap"
                                       FontSize="15" />
                            </Border>
                            <Label Text="{Binding TimestampText}"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="11"
                                   Margin="4,0,0,0" />
                        </VerticalStackLayout>

                    </Grid>
                </Grid>
            </DataTemplate>

            <!-- ── User bubble ── -->
            <DataTemplate x:Key="UserMessageTemplate"
                          x:DataType="models:ChatMessageItem">
                <Grid Padding="64,4,12,4">
                    <VerticalStackLayout Spacing="3" HorizontalOptions="End">
                        <Border Background="{StaticResource UserBubble}"
                                StrokeShape="RoundRectangle 18,18,2,18"
                                Stroke="Transparent"
                                Padding="10"
                                HorizontalOptions="End">
                            <VerticalStackLayout Spacing="6">

                                <!-- Image attachment -->
                                <Border IsVisible="{Binding HasImage}"
                                        StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent"
                                        WidthRequest="200"
                                        HeightRequest="150">
                                    <Image Source="{Binding ImageSource}"
                                           Aspect="AspectFill"
                                           WidthRequest="200"
                                           HeightRequest="150" />
                                </Border>

                                <!-- Text -->
                                <Label Text="{Binding Text}"
                                       TextColor="{StaticResource TextPrimary}"
                                       LineBreakMode="WordWrap"
                                       FontSize="15"
                                       IsVisible="{Binding HasText}" />
                            </VerticalStackLayout>
                        </Border>
                        <Label Text="{Binding TimestampText}"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="11"
                               HorizontalOptions="End"
                               Margin="0,0,4,0" />
                    </VerticalStackLayout>
                </Grid>
            </DataTemplate>

            <templates:ChatMessageTemplateSelector
                x:Key="MessageTemplateSelector"
                UserTemplate="{StaticResource UserMessageTemplate}"
                AiTemplate="{StaticResource AiMessageTemplate}" />

        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto">

        <!-- ── Header ── -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBackground}"
                Stroke="Transparent">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,3" Radius="10" Opacity="0.25" />
            </Border.Shadow>
            <Grid Padding="16,14">
                <HorizontalStackLayout Spacing="12">
                    <Border Background="{StaticResource Primary}"
                            StrokeShape="RoundRectangle 24"
                            Stroke="Transparent"
                            WidthRequest="48"
                            HeightRequest="48">
                        <Label Text="🦷"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontSize="26" />
                    </Border>
                    <VerticalStackLayout VerticalOptions="Center" Spacing="3">
                        <Label Text="DentAI"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                            <Ellipse Fill="#34D399"
                                     WidthRequest="7"
                                     HeightRequest="7"
                                     VerticalOptions="Center" />
                            <Label Text="Online"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- ── Messages ── -->
        <CollectionView x:Name="MessagesView"
                        Grid.Row="1"
                        ItemsSource="{Binding Messages}"
                        ItemTemplate="{StaticResource MessageTemplateSelector}"
                        SelectionMode="None"
                        Margin="0,6,0,6" />

        <!-- ── Typing indicator ── -->
        <Grid Grid.Row="2"
              Padding="12,0,64,8"
              IsVisible="{Binding IsBusy}">
            <Border Background="{StaticResource AiBubble}"
                    StrokeShape="RoundRectangle 18,18,18,2"
                    Stroke="Transparent"
                    Padding="14,10"
                    HorizontalOptions="Start">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.15" />
                </Border.Shadow>
                <HorizontalStackLayout Spacing="8">
                    <ActivityIndicator IsRunning="True"
                                       Color="{StaticResource Primary}"
                                       WidthRequest="18"
                                       HeightRequest="18" />
                    <Label Text="AI is typing…"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="14"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- ── Pending image preview ── -->
        <Grid Grid.Row="3"
              IsVisible="{Binding HasPendingImage}"
              BackgroundColor="{StaticResource CardBackground}"
              Padding="12,8">
            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <Border StrokeShape="RoundRectangle 10"
                        Stroke="Transparent"
                        WidthRequest="64"
                        HeightRequest="64">
                    <Image Source="{Binding PendingImageSource}"
                           Aspect="AspectFill"
                           WidthRequest="64"
                           HeightRequest="64" />
                </Border>
                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                    <Label Text="📎 Image attached"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="14"
                           FontAttributes="Bold" />
                    <Label Text="Tap ✕ to remove"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="12" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
            <Button HorizontalOptions="End"
                    VerticalOptions="Center"
                    Text="✕"
                    Command="{Binding ClearPendingImageCommand}"
                    BackgroundColor="#EF4444"
                    TextColor="{StaticResource TextPrimary}"
                    CornerRadius="16"
                    WidthRequest="32"
                    HeightRequest="32"
                    FontSize="13"
                    Padding="0"
                    BorderWidth="0" />
        </Grid>

        <!-- ── Input bar ── -->
        <Border Grid.Row="4"
                Background="{StaticResource CardBackground}"
                Stroke="Transparent">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-2" Radius="12" Opacity="0.2" />
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                  ColumnSpacing="8"
                  Padding="12,10">

                <!-- Camera -->
                <Button Grid.Column="0"
                        Text="📷"
                        Command="{Binding TakePhotoCommand}"
                        BackgroundColor="{StaticResource InputBackground}"
                        TextColor="{StaticResource TextPrimary}"
                        CornerRadius="22"
                        WidthRequest="44"
                        HeightRequest="44"
                        FontSize="19"
                        Padding="0"
                        BorderWidth="0" />

                <!-- Gallery -->
                <Button Grid.Column="1"
                        Text="🖼"
                        Command="{Binding PickPhotoCommand}"
                        BackgroundColor="{StaticResource InputBackground}"
                        TextColor="{StaticResource TextPrimary}"
                        CornerRadius="22"
                        WidthRequest="44"
                        HeightRequest="44"
                        FontSize="19"
                        Padding="0"
                        BorderWidth="0" />

                <!-- Entry -->
                <Border Grid.Column="2"
                        Background="{StaticResource InputBackground}"
                        StrokeShape="RoundRectangle 24"
                        Stroke="Transparent"
                        Padding="16,0"
                        MinimumHeightRequest="46">
                    <Entry Placeholder="Type your question…"
                           PlaceholderColor="{StaticResource TextSecondary}"
                           Text="{Binding UserInput}"
                           ReturnCommand="{Binding SendMessageCommand}"
                           VerticalOptions="Center"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="15" />
                </Border>

                <!-- Send -->
                <Button Grid.Column="3"
                        Text="➤"
                        Command="{Binding SendMessageCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource TextPrimary}"
                        CornerRadius="24"
                        WidthRequest="48"
                        HeightRequest="48"
                        FontSize="20"
                        Padding="0"
                        BorderWidth="0" />
            </Grid>
        </Border>

    </Grid>
</ContentPage>
