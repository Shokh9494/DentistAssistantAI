<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DentistAssistantAI.App.ViewModels"
             x:Class="DentistAssistantAI.App.Views.StudentPage"
             x:DataType="vm:StudentPageViewModel"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBackground}"
                Stroke="Transparent">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,3" Radius="10" Opacity="0.25" />
            </Border.Shadow>
            <Grid Padding="16,14">
                <HorizontalStackLayout Spacing="12">
                    <Border Background="{StaticResource Primary}"
                            StrokeShape="RoundRectangle 24"
                            Stroke="Transparent"
                            WidthRequest="48" HeightRequest="48">
                        <Label Text="🩺" HorizontalOptions="Center" VerticalOptions="Center" FontSize="24" />
                    </Border>
                    <Label Text="Student Practice"
                           FontSize="17" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- Scrollable content -->
        <ScrollView Grid.Row="1" Padding="16,12">
            <VerticalStackLayout Spacing="12">

                <!-- ── Card 1: Ask a Question ── -->
                <Border Background="{StaticResource CardBackground}"
                        StrokeShape="RoundRectangle 14"
                        Stroke="Transparent"
                        Padding="16">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.2" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">

                        <Label Text="💬 Ask a Question"
                               TextColor="{StaticResource TextPrimary}"
                               FontAttributes="Bold" FontSize="15" />

                        <Label Text="Your question" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                        <Border StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Primary}"
                                BackgroundColor="{StaticResource AppBackground}"
                                Padding="12,0">
                            <Entry Text="{Binding Question}"
                                   Placeholder="e.g. What is the cause of pulpitis?"
                                   PlaceholderColor="{StaticResource TextSecondary}"
                                   TextColor="{StaticResource TextPrimary}"
                                   BackgroundColor="Transparent"
                                   FontSize="15" />
                        </Border>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Course Year" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                                <Border StrokeShape="RoundRectangle 10"
                                        Stroke="{StaticResource Primary}"
                                        BackgroundColor="{StaticResource AppBackground}"
                                        Padding="4,0">
                                    <Picker ItemsSource="{Binding Years}"
                                            SelectedItem="{Binding QuestionYear}"
                                            TextColor="{StaticResource TextPrimary}"
                                            BackgroundColor="Transparent"
                                            FontSize="15" />
                                </Border>
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="📤 Send"
                                    Command="{Binding AskStudentCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="{StaticResource TextPrimary}"
                                    FontSize="13" FontAttributes="Bold"
                                    CornerRadius="10" HeightRequest="46"
                                    BorderWidth="0"
                                    VerticalOptions="End" />
                        </Grid>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="{StaticResource Primary}"
                                           HorizontalOptions="Center" />

                        <!-- Answer -->
                        <Border IsVisible="{Binding HasAnswer}"
                                BackgroundColor="{StaticResource AppBackground}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="Transparent"
                                Padding="12">
                            <Label Text="{Binding AnswerText}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="14"
                                   LineBreakMode="WordWrap" />
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- ── Card 2: Clinical Case Practice ── -->
                <Border Background="{StaticResource CardBackground}"
                        StrokeShape="RoundRectangle 14"
                        Stroke="Transparent"
                        Padding="16">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.2" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">

                        <Label Text="🎲 Clinical Case Practice"
                               TextColor="{StaticResource TextPrimary}"
                               FontAttributes="Bold" FontSize="15" />

                        <Label Text="Case topic" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                        <Border StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Primary}"
                                BackgroundColor="{StaticResource AppBackground}"
                                Padding="12,0">
                            <Entry Text="{Binding CaseTopic}"
                                   Placeholder="e.g. Acute Pulpitis"
                                   PlaceholderColor="{StaticResource TextSecondary}"
                                   TextColor="{StaticResource TextPrimary}"
                                   BackgroundColor="Transparent"
                                   FontSize="15" />
                        </Border>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Course Year" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                                <Border StrokeShape="RoundRectangle 10"
                                        Stroke="{StaticResource Primary}"
                                        BackgroundColor="{StaticResource AppBackground}"
                                        Padding="4,0">
                                    <Picker ItemsSource="{Binding Years}"
                                            SelectedItem="{Binding CaseYear}"
                                            TextColor="{StaticResource TextPrimary}"
                                            BackgroundColor="Transparent"
                                            FontSize="15" />
                                </Border>
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="🎲 Generate"
                                    Command="{Binding GenerateCaseCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="{StaticResource TextPrimary}"
                                    FontSize="13" FontAttributes="Bold"
                                    CornerRadius="10" HeightRequest="46"
                                    BorderWidth="0"
                                    VerticalOptions="End" />
                        </Grid>

                        <!-- Case text -->
                        <Border IsVisible="{Binding HasCase}"
                                BackgroundColor="{StaticResource AppBackground}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="Transparent"
                                Padding="12">
                            <Label Text="{Binding CaseText}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="14"
                                   LineBreakMode="WordWrap" />
                        </Border>

                        <!-- Answer form -->
                        <VerticalStackLayout IsVisible="{Binding HasCase}" Spacing="8">
                            <BoxView HeightRequest="1" Color="{StaticResource Primary}" Opacity="0.3" />

                            <Label Text="Your Diagnosis" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                            <Border StrokeShape="RoundRectangle 10"
                                    Stroke="{StaticResource Primary}"
                                    BackgroundColor="{StaticResource AppBackground}"
                                    Padding="12,4">
                                <Editor Text="{Binding Diagnosis}"
                                        Placeholder="Enter your diagnosis..."
                                        PlaceholderColor="{StaticResource TextSecondary}"
                                        TextColor="{StaticResource TextPrimary}"
                                        BackgroundColor="Transparent"
                                        FontSize="14"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="72" />
                            </Border>

                            <Label Text="Treatment Plan" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                            <Border StrokeShape="RoundRectangle 10"
                                    Stroke="{StaticResource Primary}"
                                    BackgroundColor="{StaticResource AppBackground}"
                                    Padding="12,4">
                                <Editor Text="{Binding Treatment}"
                                        Placeholder="Describe your treatment plan..."
                                        PlaceholderColor="{StaticResource TextSecondary}"
                                        TextColor="{StaticResource TextPrimary}"
                                        BackgroundColor="Transparent"
                                        FontSize="14"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="96" />
                            </Border>

                            <Button Text="📤 Submit Answer"
                                    Command="{Binding EvaluateCaseCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="{StaticResource TextPrimary}"
                                    FontSize="14" FontAttributes="Bold"
                                    CornerRadius="10" HeightRequest="50"
                                    BorderWidth="0"
                                    HorizontalOptions="Fill" />
                        </VerticalStackLayout>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="{StaticResource Primary}"
                                           HorizontalOptions="Center" />

                        <!-- Feedback -->
                        <Border IsVisible="{Binding HasFeedback}"
                                BackgroundColor="{StaticResource AppBackground}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="Transparent"
                                Padding="12">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="📊 Feedback"
                                       TextColor="{StaticResource Primary}"
                                       FontAttributes="Bold" FontSize="14" />
                                <Label Text="{Binding FeedbackText}"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="14"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
